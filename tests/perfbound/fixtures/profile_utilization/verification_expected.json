{
  "schema_version": "1.0",
  "purpose": "expected_answers_for_profile_utilization_verification",
  "source_input_file": "tests/perfbound/fixtures/profile_utilization/verification_inputs.json",
  "metric_formulas": {
    "A_actual_performance": "work_done / elapsed_time_us",
    "I_ideal_performance": "sum(work_i) / sum(work_i / peak_rate_i), or bound_work / per_component_us when work_breakdown is empty",
    "E_execution_efficiency": "U_utilization / R_active_time_ratio",
    "R_active_time_ratio": "active_time_us / elapsed_time_us",
    "U_utilization": "A_actual_performance / I_ideal_performance"
  },
