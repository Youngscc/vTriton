/*
 * Vector Peak Transcendental Microbenchmark
 *
 * Runs VEXP/VLOG/VSQRT/VRSQRT over a UB-resident 256-element FP16 tile.
 */
#include "vt_microbench_common.h"

extern "C" __global__ __aicore__ void vector_peak_transcendental(GM_ADDR x, GM_ADDR z)
{
    KERNEL_TASK_TYPE_DEFAULT(KERNEL_TYPE_AIV_ONLY);
    VTCalib::VectorTransKernel op;
    op.Init(x, z);
    op.Process();
}
